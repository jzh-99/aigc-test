# 版本控制
.git
.gitignore

# 依赖（容器内重新安装）
node_modules
**/node_modules

# 构建产物（容器内重新构建）
**/.next
**/dist
**/build

# 测试 & 开发工具
**/*.spec.ts
**/*.test.ts
**/e2e
**/.playwright
**/playwright-report
**/test-results

# 日志
**/*.log
**/logs

# 环境变量（通过 docker-compose env_file 或 environment 注入）
.env
.env.local
.env.*.local

# 编辑器 & 系统文件
.vscode
.idea
**/.DS_Store
**/Thumbs.db

# Docker 自身
Dockerfile
**/Dockerfile
docker-compose*.yml
.dockerignore

# 文档（不影响应用构建）
README.md
CHANGELOG.md
docs

# CI/CD
.github
.gitlab-ci.yml
