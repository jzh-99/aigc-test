# Dev environment template. Copy to .env on the dev server and fill real values there.

NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgresql://aigc:aigcpass@localhost:5432/aigc_dev
REDIS_URL=redis://localhost:6379/1

API_HOST=0.0.0.0
API_PORT=3001
WORKER_PORT=3002
WEB_BASE_URL=http://localhost:6008
API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:6008

JWT_SECRET=replace-with-dev-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

EXTERNAL_STORAGE_URL=
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=aigc-dev-assets
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_URL=http://localhost:9000/aigc-dev-assets

NANO_BANANA_API_URL=
NANO_BANANA_API_KEY=
VOLCENGINE_API_KEY=
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
AVATAR_UPLOAD_BASE_URL=

LIFE_SERVICE_BASE_URL=
LIFE_SERVICE_APP_ID=
LIFE_SERVICE_SECRET=
LIFE_SERVICE_PLATFORM_CODE=
