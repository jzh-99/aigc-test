# Database
DATABASE_URL=postgresql://aigc:aigcpass@localhost:5432/aigc_dev

# Redis
REDIS_URL=redis://localhost:6379

# 火山引擎 TOS 对象存储
TOS_ACCESS_KEY_ID=           # 火山引擎 AccessKeyId
TOS_SECRET_ACCESS_KEY=       # 火山引擎 SecretAccessKey
TOS_REGION=cn-shanghai
TOS_ENDPOINT=https://tos-cn-shanghai.volces.com
# bucket 按环境区分：toby-ai-dev（开发）/ toby-ai-prod（生产）
TOS_BUCKET=toby-ai-dev
# 公网访问基础 URL（格式：https://<bucket>.tos-cn-shanghai.volces.com）
TOS_PUBLIC_URL=https://toby-ai-dev.tos-cn-shanghai.volces.com

# Auth (Phase 0: static key, Phase 4: JWT)
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:3000

# API Service
API_PORT=3001
API_HOST=0.0.0.0

# Worker Service
WORKER_PORT=3002

# AI Chat 模型切换：doubao（默认）| nano_banana
AI_CHAT_PROVIDER=doubao

# 豆包 doubao-seed-2.0-lite（火山方舟 OpenAI 兼容接口）
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2.0-lite

# Nano Banana（原 Gemini 通道）
NANO_BANANA_API_URL=
NANO_BANANA_API_KEY=
NANO_BANANA_MODEL=

# AI system prompts are loaded from ./prompts.env.
# Copy prompts.env.example to prompts.env and fill in private prompt text.

# Volcengine / 火山引擎 (Seedream image + Seedance video)
VOLCENGINE_API_KEY=

# Volcengine Visual API — OmniHuman 数字人 (AK/SK 签名，与 ARK API Key 不同)
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
# 数字人上传文件的公网基础 URL（与 AI_UPLOAD_BASE_URL 相同，6006 端口反代）
AVATAR_UPLOAD_BASE_URL=

# Feature Flags
NODE_ENV=development
LOG_LEVEL=info
LOG_DIR=   # 留空则默认 logs/api 或 logs/worker（相对 monorepo 根目录）

# 生活平台支付（域名向生活平台负责人申请，getToken/orderGenerate/payViewWAP 都在同一个域名下）
LIFE_SERVICE_BASE_URL=https://[生活平台域名]
LIFE_SERVICE_APP_ID=
LIFE_SERVICE_SECRET=
LIFE_SERVICE_PLATFORM_CODE=
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
