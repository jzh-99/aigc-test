# Database
DATABASE_URL=postgresql://aigc:aigcpass@localhost:5432/aigc_dev

# Redis
REDIS_URL=redis://localhost:6379

# External Storage API (used by worker to persist generated images)
EXTERNAL_STORAGE_URL=http://<storage-server-ip>:<port>/chatAI/api/video/content

# Object Storage (MinIO / S3) — optional, used only if EXTERNAL_STORAGE_URL is not set
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=aigc-assets
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_URL=http://localhost:9000/aigc-assets

# Auth (Phase 0: static key, Phase 4: JWT)
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:3000

# API Service
API_PORT=3001
API_HOST=0.0.0.0

# Worker Service
WORKER_PORT=3002

# Third-party AI Providers (Phase 1+)
NANO_BANANA_API_URL=https://ai.comfly.chat
NANO_BANANA_API_KEY=

# Volcengine / 火山引擎 (Seedream image + Seedance video)
VOLCENGINE_API_KEY=

# Volcengine Visual API — OmniHuman 数字人 (AK/SK 签名，与 ARK API Key 不同)
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
# 数字人上传文件的公网基础 URL（与 AI_UPLOAD_BASE_URL 相同，6006 端口反代）
AVATAR_UPLOAD_BASE_URL=

# Feature Flags
NODE_ENV=development
LOG_LEVEL=info
