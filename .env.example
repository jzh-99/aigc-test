# ============================================================
# 本地开发环境变量示例
# 复制为 .env 后填写真实值，.env 不提交 git
# ============================================================

# ---- 运行环境 ----
NODE_ENV=development
LOG_LEVEL=info
LOG_DIR=   # 留空则默认 logs/api 或 logs/worker（相对 monorepo 根目录）

# ---- 服务端口 ----
API_PORT=7001
API_HOST=0.0.0.0
WORKER_PORT=3002

# ---- 服务间通信 URL ----
INTERNAL_API_URL=http://localhost:7001
WEB_BASE_URL=http://localhost:6006
API_BASE_URL=http://localhost:7001

# ---- 数据库 ----
DATABASE_URL=postgresql://aigc:aigcpass@localhost:5432/aigc_dev

# ---- Redis ----
REDIS_URL=redis://localhost:6379/1

# ---- JWT ----
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- CORS（逗号分隔的允许来源）----
CORS_ORIGIN=http://localhost:6006

# ============================================================
# 对象存储
# 生产环境：STORAGE_DRIVER 留空，走火山引擎 TOS
# 本地开发：STORAGE_DRIVER=s3，走本地 MinIO（docker-compose 已内置）
# ============================================================

# 生产 TOS 配置（本地开发可留空，走下方 S3/MinIO）
TOS_ACCESS_KEY_ID=           # 火山引擎 AccessKeyId
TOS_SECRET_ACCESS_KEY=       # 火山引擎 SecretAccessKey
TOS_REGION=cn-shanghai
TOS_ENDPOINT=https://tos-cn-shanghai.volces.com
TOS_BUCKET=toby-ai-dev       # 生产改为 toby-ai-prod
TOS_PUBLIC_URL=https://toby-ai-dev.tos-cn-shanghai.volces.com

# 本地开发 MinIO（STORAGE_DRIVER=s3 时生效，生产删除或注释）
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9001
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
# MinIO 上传后返回的 URL 前缀（仅 API 层上传用，不影响 worker 的 TOS 转存）
# TOS_PUBLIC_URL 始终保持 TOS 真实地址，worker 转存图片写入数据库的 URL 不受影响
S3_PUBLIC_URL=http://localhost:9000/toby-ai-dev

# ============================================================
# AI 服务
# ============================================================

# AI Chat 模型切换：doubao（默认）| nano_banana
AI_CHAT_PROVIDER=doubao

# 豆包（火山方舟 OpenAI 兼容接口）
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-seed-2.0-lite

# Nano Banana（Gemini 通道，canvas-agent / video-studio / ai-assistant 备用）
NANO_BANANA_API_URL=
NANO_BANANA_API_KEY=
NANO_BANANA_MODEL=

# AI system prompts 从 ./prompts.env 加载
# 复制 prompts.env.example 为 prompts.env 并填写私有提示词

# 火山引擎（Seedream 图片 + Seedance 视频）
VOLCENGINE_API_KEY=

# 火山引擎 Visual API — OmniHuman 数字人（AK/SK 签名，与 ARK API Key 不同）
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=

# 代理基础 URL：worker 将内网存储 URL 包装为外部可访问的代理地址
# 本地开发填 http://localhost:7001，生产填 API 服务器公网地址
AVATAR_UPLOAD_BASE_URL=http://localhost:7001

# ============================================================
# 支付（生活平台）
# 域名向生活平台负责人申请，getToken/orderGenerate/payViewWAP 同域名
# ============================================================
LIFE_SERVICE_BASE_URL=https://[生活平台域名]
LIFE_SERVICE_APP_ID=
LIFE_SERVICE_SECRET=
LIFE_SERVICE_PLATFORM_CODE=

# 包月订阅参数（需对方提供）
LIFE_SERVICE_TEMPLATE_CODE=PENDING
LIFE_SERVICE_SKU_ID=PENDING
LIFE_SERVICE_SPU_ID=PENDING
LIFE_SERVICE_AREA_CODE=025

# ============================================================
# 其他外部服务（按需填写）
# ============================================================
EXTERNAL_STORAGE_URL=
EXTERNAL_STORAGE_BASE=
COMPANY_A_IMAGE_BASE=
NEXT_PUBLIC_API_URL=
