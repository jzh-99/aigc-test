# Worker 服务器环境变量
# 复制为 .env 后填写真实值

# ---- 基础设施服务器地址 ----
INFRA_HOST=192.168.1.100        # 基础设施服务器 IP 或域名

# ---- 数据库 ----
POSTGRES_USER=aigc
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aigc_dev
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379
REDIS_PASSWORD=                  # 与基础设施服务器保持一致

# ---- 对象存储 ----
STORAGE_ACCESS_KEY=change-me-access-key
STORAGE_SECRET_KEY=change-me-secret-key
STORAGE_BUCKET=aigc-assets
STORAGE_REGION=us-east-1
MINIO_API_PORT=9000

NANO_BANANA_API_URL=
NANO_BANANA_API_KEY=

# ---- 第三方 AI 服务 ----
VOLCENGINE_API_KEY=
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=

# ---- 外部存储（生成结果持久化）----
EXTERNAL_STORAGE_URL=

# ---- 日志 ----
LOG_LEVEL=info
NODE_ENV=production
