# 基础设施服务器环境变量
# 复制为 .env 后填写真实值

# PostgreSQL
POSTGRES_USER=aigc
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aigc_dev
POSTGRES_PORT=5432

# Redis（留空则不设密码）
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO 对象存储
STORAGE_ACCESS_KEY=change-me-access-key
STORAGE_SECRET_KEY=change-me-secret-key
STORAGE_BUCKET=aigc-assets
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
