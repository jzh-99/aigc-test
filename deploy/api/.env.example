# API 服务器环境变量
# 复制为 .env 后填写真实值

# ---- 基础设施服务器地址 ----
INFRA_HOST=192.168.1.100        # 基础设施服务器 IP 或域名

# ---- 数据库 ----
POSTGRES_USER=aigc
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aigc_dev
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379
REDIS_PASSWORD=                  # 与基础设施服务器保持一致

# ---- 对象存储 ----
STORAGE_ACCESS_KEY=change-me-access-key
STORAGE_SECRET_KEY=change-me-secret-key
STORAGE_BUCKET=aigc-assets
STORAGE_REGION=us-east-1
MINIO_API_PORT=9000

# ---- JWT ----
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---- CORS（允许 web 服务器访问）----
CORS_ORIGIN=http://WEB_SERVER_IP:6006

# ---- API 端口 ----
API_PORT=7001

GEMINI_MODEL=gemini-3-flash-preview-thinking-*

NEXT_PUBLIC_API_URL=
EXTERNAL_STORAGE_URL=
EXTERNAL_STORAGE_BASE=
COMPANY_A_IMAGE_BASE=
NANO_BANANA_API_KEY=

# ---- 第三方 AI 服务 ----
VOLCENGINE_API_KEY=
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
AVATAR_UPLOAD_BASE_URL=

# ---- 支付 ----
LIFE_SERVICE_BASE_URL=
LIFE_SERVICE_APP_ID=
LIFE_SERVICE_SECRET=
LIFE_SERVICE_PLATFORM_CODE=
WEB_BASE_URL=http://WEB_SERVER_IP:6006
API_BASE_URL=http://API_SERVER_IP:7001

# ---- Cookie 安全 ----
# HTTPS 部署时设为 true，HTTP 部署时设为 false（否则浏览器会拒绝存储 Cookie）
COOKIE_SECURE=false

# ---- 日志 ----
LOG_LEVEL=info
NODE_ENV=production

# 包月订阅参数（需对方提供）
LIFE_SERVICE_TEMPLATE_CODE=PENDING
LIFE_SERVICE_SKU_ID=PENDING
LIFE_SERVICE_SPU_ID=PENDING
LIFE_SERVICE_AREA_CODE=025
